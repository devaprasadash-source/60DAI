import pyautogui
import time
import os

# Small delay so you can see what's happening
pyautogui.PAUSE = 1

# Open Windows Calculator
os.system("start calc")

# Wait for calculator to open
time.sleep(3)

# Type calculation: 7 + 3 =
pyautogui.press('7')
pyautogui.press('+')
pyautogui.press('3')
pyautogui.press('enter')

print("Calculation Completed!")
